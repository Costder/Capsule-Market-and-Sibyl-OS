    "./crypto-node": "./src/crypto-node.js",
    "./crypto-noble": "./src/crypto-noble.js"
  },
  "scripts": {
    "test": "node --test"
  },
  "license": "MIT",
  "peerDependencies": {
    "@noble/ed25519": "^2.0.0",
    "@noble/hashes": "^1.4.0"
  },
