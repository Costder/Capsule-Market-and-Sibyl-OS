{
  "name": "@sibyl/trust",
  "version": "0.0.1",
  "description": "OpenTrust passport verification + capability gating for Capsule Market / Sibyl OS. Pure portable core with pluggable ed25519 adapters (Node built-in crypto, or @noble for React Native).",
