{
  "name": "@sibyl/capsule-spec",
  "version": "0.0.1",
  "description": "The Capsule manifest format for Capsule Market / Sibyl OS — JSON Schema + TypeScript types + validator. The keystone contract every other package keys off.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema": "./capsule.schema.json"
  },
  "files": [
    "dist",
    "capsule.schema.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --test"
  },
  "keywords": [
    "sibyl",
    "capsule",
    "manifest",
    "opentrust",
    "mobile"
  ],
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "ajv": "^8.17.0"
  }
}
